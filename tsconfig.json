{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "sourceMap": true,
    "rootDir": "src",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "vscode-languageclient/node": ["./node_modules/vscode-languageclient/lib/node/main.d.ts"],
      "vscode-languageclient": ["./node_modules/vscode-languageclient/lib/common/api.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", ".vscode-test", "src/webview", "src/lsp/server", "src/lsp/js", "hello-webview-repro"]
}
